{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with cantons access",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["elu", "admin"] },
        "cantons": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["email", "role", "cantons", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile containing access info"
    }
  }
}
